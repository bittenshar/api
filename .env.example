# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REKOGNITION_COLLECTION_ID=your_collection_id_here

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/face_verification

# Server Configuration
PORT=3000
NODE_ENV=development

# Performance & Logging
LOG_LEVEL=info
FACE_MATCH_THRESHOLD=90
MAX_FACES=1
